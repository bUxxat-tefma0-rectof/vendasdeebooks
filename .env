# ============================================
# CONFIGURAÇÕES DO BOT TELEGRAM
# ============================================
BOT_TOKEN=SEU_TOKEN_DO_BOT_AQUI
NOME_BOT=StoreBot
VERSAO_BOT=1.0.0

# ============================================
# CONFIGURAÇÕES POSTGRESQL
# ============================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=sua_senha_segura
PG_DATABASE=bot_vendas
PG_POOL_SIZE=10
PG_MAX_OVERFLOW=20

# URL completa (usada pelo SQLAlchemy)
DATABASE_URL=postgresql://postgres:sua_senha_segura@localhost:5432/bot_vendas

# Para desenvolvimento local com SQLite:
# DATABASE_URL=sqlite:///bot_vendas.db

# ============================================
# CONFIGURAÇÕES DO MERCADO PAGO
# ============================================
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxx

# ============================================
# CONFIGURAÇÕES DE ADMINISTRADORES
# ============================================
ADMIN_IDS=123456789,987654321

# ============================================
# CONFIGURAÇÕES DO PIX
# ============================================
VALOR_MINIMO_PIX=10.00
VALOR_MAXIMO_PIX=500.00
TEMPO_EXPIRACAO_PIX=300
BONUS_DEPOSITO_PORCENTAGEM=5.0

# ============================================
# CONFIGURAÇÕES DE AFILIADOS
# ============================================
COMISSAO_AFILIADO_PADRAO=10.0
SISTEMA_AFILIADOS_ATIVO=true

# ============================================
# LOGS E MONITORAMENTO
# ============================================
LOG_LEVEL=INFO
LOG_FILE=bot_vendas.log
CANAL_LOG_ID=

# ============================================
# LINKS
# ============================================
GRUPO_SUPORTE_LINK=https://t.me/seu_grupo_suporte
TERMOS_USO_LINK=https://telegra.ph/Seus-Termos-de-Uso

# ============================================
# TIMEZONE
# ============================================
TIMEZONE=America/Sao_Paulo
