# ============================================
# CONFIGURAÇÕES DO BOT TELEGRAM
# ============================================

# Token do Bot (obrigatório)
BOT_TOKEN=SEU_TOKEN_DO_BOT_AQUI

# Nome do Bot
NOME_BOT=StoreBot

# Versão do Sistema
VERSAO_BOT=1.0.0


# ============================================
# CONFIGURAÇÕES DO MERCADO PAGO
# ============================================

# Access Token (obrigatório)
MP_ACCESS_TOKEN=SUA_CHAVE_DE_ACESSO_AQUI

# Public Key
MP_PUBLIC_KEY=SUA_CHAVE_PUBLICA_AQUI

# Client ID e Client Secret (para webhooks)
MP_CLIENT_ID=SEU_CLIENT_ID_AQUI
MP_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI


# ============================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ============================================

# PostgreSQL (produção)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# SQLite (desenvolvimento)
# DATABASE_URL=sqlite:///bot_vendas.db


# ============================================
# CONFIGURAÇÕES DE ADMINISTRADORES
# ============================================

# IDs dos administradores (separados por vírgula)
ADMIN_IDS=123456789,987654321


# ============================================
# CONFIGURAÇÕES DO GATEWAY DE PAGAMENTO
# ============================================

# Valores mínimo e máximo para recarga
VALOR_MINIMO_PIX=10.00
VALOR_MAXIMO_PIX=500.00

# Tempo de expiração do QR Code em segundos (5 minutos)
TEMPO_EXPIRACAO_PIX=300

# Porcentagem de bônus no depósito
BONUS_DEPOSITO_PORCENTAGEM=5.0


# ============================================
# CONFIGURAÇÕES DE AFILIADOS
# ============================================

# Comissão padrão para afiliados (%)
COMISSAO_AFILIADO_PADRAO=10.0

# Ativar sistema de afiliados
SISTEMA_AFILIADOS_ATIVO=true


# ============================================
# CONFIGURAÇÕES DE LOGS
# ============================================

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Arquivo de log
LOG_FILE=bot_vendas.log


# ============================================
# CONFIGURAÇÕES DE REDIS (opcional)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=


# ============================================
# CONFIGURAÇÕES GERAIS
# ============================================

# Timezone
TIMEZONE=America/Sao_Paulo

# Idioma padrão
IDIOMA_PADRAO=pt-BR

# Canal de logs (Telegram)
CANAL_LOG_ID=

# Grupo de suporte
GRUPO_SUPORTE_LINK=https://t.me/seu_grupo_suporte

# Termos de uso (Telegraph)
TERMOS_USO_LINK=https://telegra.ph/Seus-Termos-de-Uso
